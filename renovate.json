{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "separateMajorMinor": false,
  "separateMinorPatch": false,
  "dependencyDashboard": false,
  "rangeStrategy": "bump",
  "rebaseWhen": "behind-base-branch",
  "prHourlyLimit": 0,
  "prConcurrentLimit": 0,
  "lockFileMaintenance": { "enabled": false }
}
